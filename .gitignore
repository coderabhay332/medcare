# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Compiled output
dist/
tmp/
out-tsc/
*.tsbuildinfo
.expo
.expo-shared

# Dependencies
node_modules/

# Environment variables (sensitive!)
.env
.env.*
!.env.example

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

# NX / Cursor / GitHub Copilot generated rules
.cursor/
.github/instructions/

# Replit specific
.replit
.replitignore
.replit-artifact/
.cache/
.local/

# Large data files (too big for git)
medicine_details.csv
*.csv

# Build artifacts & source maps
*.map

# Upload directories (user uploads, temp files)
artifacts/api-server/uploads/

# Scratch / test files
artifacts/api-server/scratch-test.js

# Agents
.agents/

# Lock files (optional — keep pnpm-lock.yaml for reproducibility, ignore others)
package-lock.json
yarn.lock
